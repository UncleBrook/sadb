#!/usr/bin/env bash

# ==============================================================================
# sadb - Smart ADB Wrapper
# ==============================================================================

c_green=$(tput setaf 2)
c_error=$(tput setaf 1)
c_cyan=$(tput setaf 6)
c_gray=$(tput setaf 8 2>/dev/null || tput setaf 7)
c_yellow=$(tput setaf 3)
c_bold=$(tput bold)
c_reset=$(tput sgr0)
adb_bin=$(which adb)
config="${HOME}/.config/sadb/"
mkdir -p "$config"

declare -A dic_device
declare -A alias
declare -A methods
nums=()
active_device_num=-1
FIRST_EXEC=true

[[ ! -e "${config}.alias" ]] && touch "${config}.alias"

read_alias() {
    alias=()
    methods=()
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        if [[ "$line" =~ ^[[:space:]]*([a-zA-Z0-9_-]+)[[:space:]]*\(\)[[:space:]]*\{ ]]; then
            local method_name="${BASH_REMATCH[1]}"
            local method_body=""
            while IFS= read -r next_line || [[ -n "$next_line" ]]; do
                if [[ "$next_line" =~ ^[[:space:]]*\}[[:space:]]*$ ]]; then
                    break
                fi
                method_body+="$next_line"$'\n'
            done
            methods["$method_name"]="$method_body"
        elif [[ "$line" == *"="* ]]; then
            local key="${line%%=*}"
            local value="${line#*=}"
            
            # Use native Bash trimming to avoid glob expansion and subshells
            key="${key#"${key%%[![:space:]]*}"}"
            key="${key%"${key##*[![:space:]]}"}"
            value="${value#"${value%%[![:space:]]*}"}"
            value="${value%"${value##*[![:space:]]}"}"
            
            # Validate key: must not be empty and must be a valid shell identifier
            # Although associative arrays support most characters, it's safer to avoid weird ones
            if [[ -n "$key" ]]; then
                alias["$key"]="$value"
            fi
        fi
    done < "${config}.alias"
}

add_alias() {
    local key="$1"
    local value="${*:2}"
    
    # Validate key: only allow alphanumeric, underscore, hyphen, and dot
    if [[ ! "$key" =~ ^[a-zA-Z0-9._-]+$ ]]; then
        printf "${c_error}Error: Invalid alias name '$key'. Only alphanumeric, '.', '_' and '-' are allowed.${c_reset}\n"
        exit 1
    fi

    if [[ -v methods["$key"] ]]; then
        printf "A method with the same name ${c_yellow}'$key'${c_reset} already exists.\n"
        printf "A method always takes precedence over an alias. Continue? ${c_green}[y/n]${c_reset}:"
        read -r answer
        [[ "$answer" != [Yy]* ]] && exit 0
    fi

    if [[ -v alias["$key"] ]]; then
        printf "The original alias is ${c_error}'$key=${alias[$key]}'${c_reset}, overwrite it? ${c_green}[y/n]${c_reset}:"
        read -r answer
        [[ "$answer" != [Yy]* ]] && exit 0
        remove_alias "$key"
    fi
    echo "$key=$value" >> "${config}.alias"
    read_alias
}

remove_alias() {
    local key="$1"
    local has_alias=false
    local has_method=false

    [[ -v alias["$key"] ]] && has_alias=true
    [[ -v methods["$key"] ]] && has_method=true

    # Escape key for sed pattern
    local escaped_key=$(echo "$key" | sed 's/[^^]/[&]/g; s/\^/\\^/g')

    if $has_alias && $has_method; then
        printf "Conflict: \"%s\" is both an ${c_cyan}Alias${c_reset} and a ${c_yellow}Method${c_reset}.\n" "$key"
        printf "What would you like to remove?\n"
        printf "  1) Both\n"
        printf "  2) Only Alias\n"
        printf "  3) Only Method\n"
        printf "  n) Cancel\n"
        printf "Selection [1-3, n]: "
        read -r choice
        case "$choice" in
            1)
                sed_i "/^[[:space:]]*$escaped_key=/d" "${config}.alias"
                sed_i "/^[[:space:]]*$escaped_key[[:space:]]*()[[:space:]]*{/,/^[[:space:]]*}/d" "${config}.alias"
                ;;
            2)
                sed_i "/^[[:space:]]*$escaped_key=/d" "${config}.alias"
                ;;
            3)
                sed_i "/^[[:space:]]*$escaped_key[[:space:]]*()[[:space:]]*{/,/^[[:space:]]*}/d" "${config}.alias"
                ;;
            *)
                return 0
                ;;
        esac
        read_alias
        return 0
    fi

    local found=false
    if $has_alias; then
        sed_i "/^[[:space:]]*$escaped_key=/d" "${config}.alias"
        found=true
    fi

    if $has_method; then
        sed_i "/^[[:space:]]*$escaped_key[[:space:]]*()[[:space:]]*{/,/^[[:space:]]*}/d" "${config}.alias"
        found=true
    fi

    if $found; then
        read_alias
    else
        printf "Alias or Method \"%s\" not found.\n" "$key"
        print_alias
    fi
}

show_alias() {
    [[ -v alias["$1"] ]] && printf "%s=%s\n" "$1" "${alias[$1]}"
}

print_alias() {
    local mode="${1:-alpha}"
    local alias_keys=("${!alias[@]}")
    local method_keys=("${!methods[@]}")

    # 排序逻辑
    sort_keys() {
        local input_keys=("$@")
        case "$mode" in
            a|alpha)   printf "%s\n" "${input_keys[@]}" | sort ;;
            r|reverse) printf "%s\n" "${input_keys[@]}" | sort -r ;;
            l|length)  printf "%s\n" "${input_keys[@]}" | awk '{ print length, $0 }' | sort -n | cut -d" " -f2- ;;
            *)         printf "%s\n" "${input_keys[@]}" ;;
        esac
    }

    local sorted_alias=($(sort_keys "${alias_keys[@]}"))
    local sorted_methods=($(sort_keys "${method_keys[@]}"))

    printf "${c_gray}---${c_reset} ${c_cyan}Aliases${c_reset} ${c_gray}---${c_reset}\n"
    for key in "${sorted_alias[@]}"; do
        [[ -n "$key" ]] && printf "alias.${c_green}%-20s${c_reset} = %s\n" "$key" "${alias[$key]}"
    done

    printf "\n${c_gray}---${c_reset} ${c_cyan}Methods${c_reset} ${c_gray}---${c_reset}\n"
    for key in "${sorted_methods[@]}"; do
        [[ -n "$key" ]] && printf "method.${c_yellow}%s${c_reset}() {\n%s}\n\n" "$key" "${methods[$key]}"
    done
}

sed_i() {
    [[ "$OSTYPE" == "darwin"* ]] && sed -i '' "$@" || sed -i "$@"
}

exec_adb() {
    local num=$(( ${1:-0} + 2 ))
    local device=$(sed -n "${num}p" <<< "$devices")
    [[ -z "$device" ]] && return
    
    parse_device "$device"
    local sn="${dic_device[sn]}"
    local model="${dic_device[model]:-$sn}"
    export ANDROID_SERIAL="$sn"

    local cmd_key="${adb_args[0]}"
    
    # 如果命令是 active，则执行锁定逻辑而不是 adb 命令
    if [[ "$cmd_key" == "active" ]]; then
        set_active_device "$sn"
        return
    fi

    local method_body="${methods[$cmd_key]}"
    local alias_args="${alias[$cmd_key]}"

    # 在每个设备的标题前打印标题
    [[ "$FIRST_EXEC" == "false" ]] && printf "\n" >&2
    printf "${c_gray}--- %s (%s) ---${c_reset}\n" "$sn" "$model" >&2
    FIRST_EXEC=false

    if [[ -n "$method_body" ]]; then
        printf "${c_gray}> Method: %s${c_reset}\n" "$cmd_key" >&2
        (
            set -- "${adb_args[@]:1}"
            adb() {
                printf "\n${c_gray}> Command: adb %s${c_reset}\n\n" "$*" >&2
                command adb "$@"
            }
            eval "$method_body"
        )
    elif [[ -n "$alias_args" ]]; then
        printf "${c_gray}> Command: adb %s %s${c_reset}\n\n" "${alias_args}" "${adb_args[*]:1}" >&2
        command adb -s "$sn" ${alias_args} "${adb_args[@]:1}"
    else
        printf "${c_gray}> Command: adb %s${c_reset}\n\n" "${adb_args[*]}" >&2
        command adb -s "$sn" "${adb_args[@]}"
    fi
}

choose_device() {
    if [ $active_device_num -ne -1 ]; then
        exec_adb "$active_device_num"
        exit 0
    fi

    local total_line=$(( device_count - 2 ))
    local tips="Multiple devices found. Please select ${c_green}[0 .. ${total_line}]${c_reset}: "
    [[ "${adb_args[0]}" != "active" ]] && tips="Multiple devices found. Please select ${c_green}[0 .. ${total_line}]${c_reset} or ${c_green}[a]${c_reset} for all: "
    local input=""
    local print_list=false

    # 1. 默认使用 fzf (如果已安装)
    if command -v fzf >/dev/null 2>&1; then
        local choice
        choice=$(printf "%s\n" "${details[@]:1}" | fzf --header="${details[0]}" --ansi --prompt="📱 Select device: " --height=40% --layout=reverse --border)
        if [[ -n "$choice" ]]; then
            if [[ "$choice" == *"[ a ]"* ]]; then
                for s in "${nums[@]}"; do [[ "$s" =~ [0-9]+ ]] && exec_adb "$s"; done
                exit 0
            else
                local num=$(echo "$choice" | sed -n 's/.*\[ \([0-9]\{1,\}\) \].*/\1/p')
                [[ -n "$num" ]] && { exec_adb "$num"; exit 0; }
            fi
        else
            print_list=true
        fi
    else
        print_list=true
    fi

    if $print_list; then
        for line in "${details[@]}"; do echo -e "$line" >&2; done
        echo -n "$tips" >&2
    fi

    while :; do
        [[ -z "$input" ]] && read -r input
        if [[ " ${nums[*]} " == *" ${input} "* ]]; then
            if [[ "$input" == [aA] ]]; then
                for s in "${nums[@]}"; do [[ "$s" =~ [0-9]+ ]] && exec_adb "$s"; done
            else
                exec_adb "$input"
            fi
            exit 0
        fi
        input=""
        echo -n "$tips" >&2
    done
}

# 解析并列出设备信息
# 参数 $1: "list" 表示仅列出(不进入选择逻辑)
print_devices() {
    local list_only=$1
    active_device_num=-1
    [[ -z "$devices" ]] && devices=$(command adb devices -l)
    device_count=$(wc -l <<< "$devices")
    
    # 无设备连接
    if [[ "$device_count" -eq 1 ]]; then
        printf "${c_yellow}No devices attached${c_reset}\n\n"
        exit 0
    fi

    # 自动执行逻辑：如果只有一台设备且不是单纯的 list 模式，则直接执行
    if [[ -z "$list_only" && "$device_count" -eq 2 ]]; then
        exec_adb
        exit 0
    fi

    # 获取当前会话锁定的设备 (PPID 绑定)
    local session_config="/tmp/sadb_active_${USER}_${PPID}"
    local active="${ACTIVE_DEVICE}"
    [[ -z "$active" && -f "$session_config" ]] && active=$(cat "$session_config")
    
    # 打印表头
    local header=$(printf "${c_bold}%-8s %-28s %-15s %-25s %s${c_reset}" "ID" "SERIAL" "STATUS" "MODEL" "PRODUCT")
    details=("$header")
    
    # 遍历 adb 输出的每一行设备信息
    local current_line_num=1
    while IFS= read -r line; do
        ((current_line_num++))
        [[ $current_line_num -le 2 ]] && continue # 跳过第一行 List of devices attached
        [[ -z "$line" ]] && continue

        num=$(( current_line_num - 3 ))
        nums[$num]=$num
        parse_device "$line"
        
        # 根据设备状态设置颜色
        local status_color="$c_green"
        [[ "${dic_device[device_type]}" == "offline" ]] && status_color="$c_error"
        [[ "${dic_device[device_type]}" == "unauthorized" ]] && status_color="$c_yellow"

        local id_str="[ $num ]"
        
        # 处理活动设备逻辑
        if [ "$active" = "${dic_device[sn]}" ]; then
            active_device_num=$num
            # 如果不是单纯列表模式，匹配到 active 即可跳出准备执行
            [[ -z "$list_only" ]] && break
            
            # 列表模式下，高亮显示活动设备行（整行黄色加粗）
            local row=$(printf "${c_bold}${c_yellow}%-8s %-28s %-15s %-25s %s${c_reset}" \
                      "$id_str" "${dic_device[sn]}" "${dic_device[device_type]}" "${dic_device[model]}" "${dic_device[product]}")
            details+=("${row}")
        else
            # 普通设备行，使用列着色
            local row=$(printf "${c_cyan}%-8s${c_reset} %-28s ${status_color}%-15s${c_reset} %-25s %s" \
                      "$id_str" "${dic_device[sn]}" "${dic_device[device_type]}" "${dic_device[model]}" "${dic_device[product]}")
            details+=("${row}")
        fi
    done <<< "$devices"

    # 交互模式下的额外选项
    if [[ -z "$list_only" ]]; then
        # 如果是 active 命令，不显示 "All devices" 选项
        if [[ "${adb_args[0]}" != "active" ]]; then
            if [ $active_device_num -eq -1 ]; then
                details+=("$(printf "${c_cyan}%-8s${c_reset} %-28s" "[ a ]" "All devices")")
            fi
            nums+=(a A)
        fi
    fi
}

# 解析 adb devices -l 的单行输出到关联数组
parse_device() {
    local line="$1"
    # 清空之前的状态
    dic_device=()
    
    # 1. 提取序列号和状态 (前两个字段)
    # 序列号可能包含冒号 (如 192.168.1.1:5555)
    dic_device[sn]=$(echo "$line" | awk '{print $1}')
    dic_device[device_type]=$(echo "$line" | awk '{print $2}')
    
    # 2. 提取其余属性 (product:xxx, model:xxx 等)
    local rest=$(echo "$line" | cut -d' ' -f3-)
    local key value
    IFS=" " read -ra props <<< "$rest"
    for prop in "${props[@]}"; do
        if [[ "$prop" == *":"* ]]; then
            IFS=':' read -r key value <<< "$prop"
            dic_device["$key"]="$value"
        fi
    done
}

print_exec_time() {
    printf "${c_gray}[ $(date "+%Y-%m-%d %H:%M:%S") ]${c_reset}\n\n" >&2
}

set_active_device() {
    [[ -z "$1" ]] && { printf "${c_error}Error: Serial number required${c_reset}\n"; exit 1; }
    echo "$1" > "/tmp/sadb_active_${USER}_${PPID}"
    printf "Active device set to: ${c_green}%s${c_reset} (Session-only)\n" "$1"
}

unset_active_device() {
    rm -f "/tmp/sadb_active_${USER}_${PPID}"
    printf "Active device ${c_yellow}unset${c_reset} for this session\n"
}

usage() {
    printf "${c_bold}sadb - Smart ADB Wrapper${c_reset}\n\n"
    printf "${c_bold}用法:${c_reset} sadb [命令|别名] [参数...]\n\n"
    printf "${c_bold}扩展命令:${c_reset}\n"
    printf "  active [sn|-d|-h]    管理当前会话的活动设备 (Session-only)\n"
    printf "  alias  [选项]         管理别名和自定义方法 (输入 'sadb alias -h' 查看详情)\n"
    printf "  devices              显示美化的已连接设备列表\n\n"
    printf "${c_bold}标准 ADB 命令:${c_reset}\n"
    printf "  支持所有标准 adb 命令 (如 shell, logcat, install, push 等)\n"
    printf "  当存在多台设备时，会自动触发交互式选择或使用已锁定的活动设备\n"
}

main() {
    adb_args=("$@")
    case "$1" in
        -h|--help|help)
            usage ;;
        ""|-s|-p|-e|-d|start-server|kill-server|disconnect|connect|pair|version|--version|server-status|track-devices|keygen|reconnect|mdns|host-features|emu)
            command adb "${adb_args[@]}" ;;
        devices)
            # 使用美化的列表输出，并打印收集到的 details
            print_devices "list"
            for line in "${details[@]}"; do echo -e "$line" >&2; done
            # printf "\n" >&2
            ;;
        alias)
            case "$2" in
                -l|--list) 
                    if [[ "$3" == "-s" ]]; then
                        print_alias "${4:-alpha}"
                    else
                        print_alias "none"
                    fi
                    ;;
                -r|--remove) [[ -z "$3" ]] && exit 1 || remove_alias "$3" ;;
                -h|--help)
                    printf "${c_bold}用法:${c_reset} sadb alias [选项] [键] [值...]\n\n"
                    printf "${c_bold}选项:${c_reset}\n"
                    printf "  -l, --list [-s 模式]    列出所有别名和方法 (模式: a|alpha, r|reverse, l|length)\n"
                    printf "  -r, --remove <键>       删除指定的别名或方法\n"
                    printf "  -h, --help              显示此帮助信息\n\n"
                    printf "${c_bold}命令:${c_reset}\n"
                    printf "  sadb alias <键> <值>    添加或更新别名 (例如: sadb alias c \"shell screencap\")\n"
                    printf "  sadb alias.<键> <值>    添加别名的快捷方式\n"
                    printf "  sadb alias <键>         查看特定别名的定义\n"
                    ;;
                *) [[ $# -gt 2 ]] && add_alias "$2" "${@:3}" || show_alias "$2" ;;
            esac ;;
        alias.*)
            [[ -z "$2" ]] && exit 1 || add_alias "${1#alias.}" "${@:2}" ;;
        active)
            if [[ "$2" == "-d" ]]; then
                unset_active_device
            elif [[ "$2" == "-h" || "$2" == "--help" ]]; then
                printf "${c_bold}用法:${c_reset} sadb active [序列号 | -d | -h]\n\n"
                printf "  <无参数>      触发交互式列表选择 (或自动选择唯一设备)\n"
                printf "  <序列号>      直接锁定指定的设备序列号\n"
                printf "  -d           取消当前会话的设备锁定\n"
                printf "  -h, --help   显示此帮助信息\n\n"
                printf "注意: 锁定仅对当前终端会话有效，不会影响其他窗口。\n"
            elif [[ -n "$2" ]]; then
                set_active_device "$2"
            else
                # 不带参数时，触发列表选择或自动选择唯一设备
                print_devices
                choose_device
            fi
            ;;
        *)
            print_devices
            choose_device ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    print_exec_time
    read_alias
    main "$@"
fi
