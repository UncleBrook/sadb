#!/usr/bin/env bash

# ==============================================================================
# sadb - Smart ADB Wrapper
# ==============================================================================

c_green=$(tput setaf 2)
c_error=$(tput setaf 1)
c_cyan=$(tput setaf 6)
c_yellow=$(tput setaf 3)
c_bold=$(tput bold)
c_reset=$(tput sgr0)
adb_bin=$(which adb)
config="${HOME}/.config/sadb/"
mkdir -p "$config"

declare -A dic_device
declare -A alias
declare -A methods
nums=()
active_device_num=-1

[[ ! -e "${config}.alias" ]] && touch "${config}.alias"

read_alias() {
    alias=()
    methods=()
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        if [[ "$line" =~ ^[[:space:]]*([a-zA-Z0-9_-]+)[[:space:]]*\(\)[[:space:]]*\{ ]]; then
            local method_name="${BASH_REMATCH[1]}"
            local method_body=""
            while IFS= read -r next_line || [[ -n "$next_line" ]]; do
                if [[ "$next_line" =~ ^[[:space:]]*\}[[:space:]]*$ ]]; then
                    break
                fi
                method_body+="$next_line"$'\n'
            done
            methods["$method_name"]="$method_body"
        elif [[ "$line" == *"="* ]]; then
            local key="${line%%=*}"
            local value="${line#*=}"
            # Trim whitespace from both key and value
            key=$(echo "$key" | xargs)
            value=$(echo "$value" | xargs)
            alias["$key"]="$value"
        fi
    done < "${config}.alias"
}

add_alias() {
    local key="$1"
    local value="${*:2}"
    if [[ -v alias["$key"] ]]; then
        printf "The original alias is ${c_error}'$key=${alias[$key]}'${c_reset}, overwrite it? ${c_green}[y/n]${c_reset}:"
        read -r answer
        [[ "$answer" != [Yy]* ]] && exit 0
        remove_alias "$key"
    fi
    echo "$key=$value" >> "${config}.alias"
    read_alias
}

remove_alias() {
    if [[ -v alias["$1"] ]]; then
        sed_i "/^[[:space:]]*$1=/d" "${config}.alias"
        read_alias
    else
        printf "Alias \"%s\" not found.\n" "$1"
        print_alias
    fi
}

show_alias() {
    [[ -v alias["$1"] ]] && printf "%s=%s\n" "$1" "${alias[$1]}"
}

print_alias() {
    for key in "${!alias[@]}"; do printf "alias.%s=%s\n" "$key" "${alias[$key]}"; done
    for key in "${!methods[@]}"; do printf "method.%s() {\n%s}\n" "$key" "${methods[$key]}"; done
}

sed_i() {
    [[ "$OSTYPE" == "darwin"* ]] && sed -i '' "$@" || sed -i "$@"
}

exec_adb() {
    local num=$(( ${1:-0} + 2 ))
    local device=$(sed -n "${num}p" <<< "$devices")
    [[ -z "$device" ]] && return
    
    IFS=" " read -ra args <<< "${device//\// }"
    local sn="${args[0]}"
    export ANDROID_SERIAL="$sn"

    local cmd_key="${adb_args[0]}"
    local method_body="${methods[$cmd_key]}"
    local alias_args="${alias[$cmd_key]}"

    printf "\n" >&2
    if [[ -n "$method_body" ]]; then
        printf "${c_cyan}${c_bold}>>> Method: ${c_yellow}%s${c_reset}${c_cyan} on ${c_green}%s${c_reset}\n" "$cmd_key" "$sn" >&2
        (
            set -- "${adb_args[@]:1}"
            adb() {
                printf "\n${c_cyan}${c_bold}>>> Command: ${c_green}%s -s %s ${c_yellow}%s${c_reset}\n\n" "adb" "$ANDROID_SERIAL" "$*" >&2
                command adb "$@"
                printf "\n" >&2
            }
            eval "$method_body"
        )
    elif [[ -n "$alias_args" ]]; then
        printf "${c_cyan}${c_bold}>>> Command: ${c_green}adb -s %s ${c_yellow}%s %s${c_reset}\n\n" "$sn" "${alias_args}" "${adb_args[*]:1}" >&2
        command adb -s "$sn" ${alias_args} "${adb_args[@]:1}"
    else
        printf "${c_cyan}${c_bold}>>> Command: ${c_green}adb -s %s ${c_yellow}%s${c_reset}\n\n" "$sn" "${adb_args[*]}" >&2
        command adb -s "$sn" "${adb_args[@]}"
    fi
    printf "\n" >&2
}

choose_device() {
    if [ $active_device_num -ne -1 ]; then
        exec_adb "$active_device_num"
        exit 0
    fi

    local total_line=$(( device_count - 2 ))
    local tips="Multiple devices found. Please select ${c_green}[0 .. ${total_line}]${c_reset} or ${c_green}[a]${c_reset} for all: "
    local input=""
    local print_list=false

    # 1. 50ms 盲打预检 (尊重肌肉记忆，避免输入不同步)
    if read -t 0.05 -n 1 -r pre_input; then
        input="$pre_input"
        [[ "$pre_input" != "" ]] && { read -r rest_input; input="${pre_input}${rest_input}"; }
        print_list=true
    # 2. 默认使用 fzf (如果已安装)
    elif command -v fzf >/dev/null 2>&1; then
        local choice
        choice=$(printf "%b\n" "${details[@]:2}" | fzf --header="${details[1]}" --ansi --prompt="📱 Select device: " --height=40% --layout=reverse --border)
        if [[ -n "$choice" ]]; then
            if [[ "$choice" == *"[ a ]"* ]]; then
                for s in "${nums[@]}"; do [[ "$s" =~ [0-9]+ ]] && exec_adb "$s"; done
                exit 0
            else
                local num=$(echo "$choice" | grep -oP "\[ \K[0-9]+(?= \])")
                [[ -n "$num" ]] && { exec_adb "$num"; exit 0; }
            fi
        else
            # fzf ESC 退出，标记需要打印列表并回退到手动输入
            print_list=true
        fi
    else
        # fzf 未安装，标记需要打印列表
        print_list=true
    fi

    # 仅当未使用 fzf 成功选择时，才在终端打印列表，避免重复输出
    if $print_list; then
        for line in "${details[@]}"; do echo -e "$line" >&2; done
        echo -n "$tips" >&2
    fi

    # 3. 标准输入循环 (回退方案)
    while :; do
        [[ -z "$input" ]] && read -r input
        if [[ " ${nums[*]} " == *" ${input} "* ]]; then
            if [[ "$input" == [aA] ]]; then
                for s in "${nums[@]}"; do [[ "$s" =~ [0-9]+ ]] && exec_adb "$s"; done
            else
                exec_adb "$input"
            fi
            exit 0
        fi
        input=""
        echo -n "$tips" >&2
    done
}

print_devices() {
    devices=$(command adb devices -l)
    device_count=$(wc -l <<< "$devices")
    [[ "$device_count" -eq 1 ]] && { printf "${c_yellow}No devices attached${c_reset}\n\n"; exit 0; }
    [[ "$device_count" -eq 2 ]] && { exec_adb; exit 0; }

    local active=$(echo $ACTIVE_DEVICE)
    # 精确对齐：ID(6), SERIAL(24), STATUS(12), MODEL(20), PRODUCT(20)
    local header=$(printf "${c_bold}%-6s %-24s %-12s %-20s %-20s${c_reset}" "ID" "SERIAL" "STATUS" "MODEL" "PRODUCT")
    details=("" "$header")
    
    for line in $(seq 2 "$device_count"); do
        num=$(( line - 2 ))
        nums[$num]=$num
        parse_device "$(sed -n "${line}p" <<< "$devices")"
        
        local status_color="$c_green"
        [[ "${dic_device[device_type]}" == "offline" ]] && status_color="$c_error"
        [[ "${dic_device[device_type]}" == "unauthorized" ]] && status_color="$c_yellow"

        if [ "$active" = "${dic_device[sn]}" ]; then
            active_device_num=$num
            break
        else
            local id_str="[ $num ]"
            details+=("$(printf "${c_cyan}%-6s${c_reset} %-24s ${status_color}%-12s${c_reset} %-20s %-20s" \
                      "$id_str" "${dic_device[sn]}" "${dic_device[device_type]}" "${dic_device[model]}" "${dic_device[product]}")")
        fi
    done

    if [ $active_device_num -eq -1 ]; then
        details+=("$(printf "${c_cyan}%-6s${c_reset} %-24s" "[ a ]" "All devices")")
    fi
    nums+=(a A)
}

parse_device() {
    local device key value
    IFS=" " read -ra device <<< "${1//\// }"
    for ((i = 0; i < ${#device[@]}; i++)); do
        IFS=':' read -r key value <<< "${device[i]}"
        [[ $i -eq 0 ]] && { value="$key"; key="sn"; }
        [[ $i -eq 1 ]] && { value="$key"; key="device_type"; }
        dic_device["$key"]="$value"
    done
}

print_exec_time() {
    printf "${c_cyan}[ $(date "+%Y-%m-%d %A %H:%M:%S") ]${c_reset}\n\n" >&2
}

set_active_device() {
    printf "%s\n${c_green}%s\n" "Run:" "export ACTIVE_DEVICE=$1"
}

unset_active_device() {
    printf "%s\n${c_green}%s\n" "Run:" "unset ACTIVE_DEVICE"
}

main() {
    adb_args=("$@")
    case "$1" in
        -s|-p|-e|-d|start-server|kill-server|disconnect|connect|pair|version|help|keygen|reconnect|mdns|host-features|emu)
            command adb "${adb_args[@]}" ;;
        devices)
            [[ $# -eq 1 ]] && command adb "${adb_args[@]}" -l || command adb "${adb_args[@]}" ;;
        alias)
            case "$2" in
                -l|--list) print_alias ;;
                -r|--remove) [[ -z "$3" ]] && exit 1 || remove_alias "$3" ;;
                *) [[ $# -gt 2 ]] && add_alias "$2" "${@:3}" || show_alias "$2" ;;
            esac ;;
        alias.*)
            [[ -z "$2" ]] && exit 1 || add_alias "${1#alias.}" "${@:2}" ;;
        active)
            [[ "$2" == "-d" ]] && unset_active_device || set_active_device "$2" ;;
        *)
            print_devices
            choose_device ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    print_exec_time
    read_alias
    main "$@"
fi
